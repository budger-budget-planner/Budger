# Budger API server — environment variables
# Copy this file to .env for local dev, or set these in your host's dashboard
# (Render, Railway, Fly.io, a VPS, etc.) for production.

# --- Database (required) ---------------------------------------------------
# Postgres connection string (Neon, Supabase, RDS, etc.)
DATABASE_URL=postgres://user:password@host:5432/dbname

# --- Sessions (required) ----------------------------------------------------
# Long random string used to sign the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- Networking / CORS -------------------------------------------------------
# Port the server listens on. Most hosts inject this automatically.
PORT=8080
# Comma-separated list of frontend origins allowed to call this API
# cross-origin with credentials (only needed if NOT proxying /api through
# your frontend host — see backend/README.md).
CORS_ORIGINS=https://your-frontend.vercel.app
# Full origin of the deployed frontend (no trailing slash). Used to build
# email verification / PIN reset links that must point at the frontend app,
# not this API server.
FRONTEND_URL=https://your-frontend.vercel.app

# --- File storage (Supabase Storage) — required for receipt uploads --------
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=budger-media

# --- Email (Resend) — required for invite emails / verification ------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=Budger <noreply@yourdomain.com>

# --- AI receipt/screenshot import (Gemini) — optional -----------------------
GEMINI_API_KEY=

# --- Web Push notifications — optional --------------------------------------
# Generate a VAPID key pair with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@yourdomain.com

# --- Apple Push Notifications (Live Activities) — optional ------------------
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=
APNS_PRIVATE_KEY=
APNS_PRODUCTION=false

# --- Error tracking (Sentry) — optional --------------------------------------
SENTRY_DSN=

# --- Misc --------------------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=info
