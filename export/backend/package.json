{
  "name": "budger-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development node --import tsx/esm src/index.ts",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps --import ./dist/instrument.mjs ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate --config ./drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config ./drizzle.config.ts",
    "db:push": "drizzle-kit push --config ./drizzle.config.ts",
    "migrate-receipts": "tsx src/scripts/migrate-receipts.ts"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@sentry/node": "^10.64.0",
    "@supabase/supabase-js": "^2.110.2",
    "@types/express-session": "^1.19.0",
    "bcryptjs": "^3.0.3",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^5",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "helmet": "^8.2.0",
    "jsonrepair": "^3.15.0",
    "pg": "^8.20.0",
    "pino": "^9",
    "pino-http": "^10",
    "resend": "^6.16.0",
    "web-push": "^3.6.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/helmet": "^4.0.0",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "@types/web-push": "^3.6.4",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.25.8",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "supertest": "^7.2.2",
    "thread-stream": "3.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.10"
  }
}
